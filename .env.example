# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — run `npm run stripe:setup` to create products/prices automatically
STRIPE_PRICE_FOCUS_COFFEE=price_...
STRIPE_PRICE_MATCHA=price_...
STRIPE_PRICE_FOCUS_COFFEE_SUBSCRIPTION=price_...
STRIPE_PRICE_MATCHA_SUBSCRIPTION=price_...

# Stripe webhook
# Local: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` and paste whsec_...
# Production: run `PRODUCTION_APP_URL=https://www.getritl.com npm run stripe:webhook:setup -- --live`
#            then add the printed STRIPE_WEBHOOK_SECRET to Vercel (Production env only).
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: card-only payment method configuration for checkout (auto-created if omitted)
# STRIPE_PAYMENT_METHOD_CONFIGURATION=pmc_...

# Roastify fulfillment — https://docs.roastify.app/docs/api-guides/quickstart
# Use rty_live_... in production (Vercel Production env)
# ROASTIFY_API_KEY=rty_test_...
# ROASTIFY_API_BASE_URL=https://api.roastify.app/v1
# ROASTIFY_SKU_FOCUS_COFFEE=your-focus-sku
# ROASTIFY_SKU_MATCHA=your-matcha-sku
# Optional overrides (defaults are parsed from product viewer URLs)
# ROASTIFY_ARTWORK_URL_FOCUS_COFFEE=https://storage.roastify.app/design-upload/...
# ROASTIFY_ARTWORK_URL_MATCHA=https://storage.roastify.app/design-upload/...
# Roastify webhooks (Connections → Developers → Webhooks in Roastify dashboard)
# Register https://www.getritul.com/api/roastify/webhook and paste the endpoint signing secret
# ROASTIFY_WEBHOOK_SECRET=whsec_...

# Fulfillment sync cron — GitHub Actions hits /api/cron/sync-fulfillment every 5 min
# Add the same value as CRON_SECRET in GitHub → Settings → Secrets → Actions
# CRON_SECRET=generate-a-long-random-string

# Abandoned checkout reminders — GitHub Actions hits /api/cron/abandoned-checkouts daily
# Requires migration 002_abandoned_checkouts.sql applied in Supabase
# ABANDONED_CHECKOUT_REMINDER_DAYS=3

# App URL (checkout return URLs; must match deployed host in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional override when registering Stripe webhooks (defaults to https://www.getritl.com)
# PRODUCTION_APP_URL=https://www.getritl.com

# Google Analytics 4 — measurement ID from Admin → Data Streams (starts with G-)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend — contact chat + order confirmation / shipping emails (https://resend.com)
# Optional: inbox for contact chat messages (default: support@getritul.com)
# CONTACT_INBOX=support@getritul.com
# RESEND_API_KEY=re_...
# Optional: verified sender after domain setup in Resend
# CONTACT_FROM_EMAIL=RITUL Operations <support@getritul.com>

# Salesforce CRM — sync Stripe customers to Account + Contact on purchase
# 1. Create a Connected App in Salesforce Setup (OAuth, refresh token enabled)
# 2. Add callback URL from `npm run salesforce:authorize` (default http://localhost:1717/oauth/callback)
# 3. Run `npm run salesforce:authorize` to obtain tokens, then `npm run salesforce:verify`
# SALESFORCE_CLIENT_ID=3MVG9...
# SALESFORCE_CLIENT_SECRET=...
# SALESFORCE_REFRESH_TOKEN=...
# SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
# OAuth login host — use login.salesforce.com (prod) or test.salesforce.com (sandbox)
# Do NOT use your My Domain URL (e.g. mycompany.my.salesforce.com) here
# SALESFORCE_LOGIN_URL=https://login.salesforce.com
# Optional: custom Contact field API name for Stripe customer id (e.g. Stripe_Customer_Id__c)
# SALESFORCE_STRIPE_CUSTOMER_FIELD=Stripe_Customer_Id__c

# Supabase — employee admin portal auth + orders database
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (required for orders table + webhooks)
# Run supabase/migrations/001_orders.sql in Supabase SQL Editor, then:
# npm run orders:backfill
# Optional: comma-separated email domains allowed to sign in (default: getritl.com)
# ADMIN_ALLOWED_EMAIL_DOMAINS=getritl.com

# --- Vercel Production checklist (Settings → Environment Variables) ---
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_PRICE_* (live price IDs — run stripe:setup with live keys)
# STRIPE_WEBHOOK_SECRET=whsec_... (from npm run stripe:webhook:setup -- --live)
# NEXT_PUBLIC_APP_URL=https://www.getritl.com
# ROASTIFY_API_KEY=rty_live_...
# ROASTIFY_SKU_* + optional ROASTIFY_ARTWORK_URL_*
# ROASTIFY_WEBHOOK_SECRET=whsec_... (from Roastify webhook endpoint)
# RESEND_API_KEY=re_...
# CONTACT_INBOX=support@getritul.com
# CONTACT_FROM_EMAIL=RITUL Operations <support@getritul.com>
# NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional Salesforce vars (SALESFORCE_CLIENT_ID, REFRESH_TOKEN, INSTANCE_URL, ...)
